{%- liquid
  assign auto_rotate = section.settings.auto_rotate
  assign change_slides_speed = section.settings.change_slides_speed | times: 1000
  assign font_size = section.settings.font_size
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign announcement_bg = section.settings.announcement_bg
  assign announcement_text_color = section.settings.announcement_text_color
-%}

{%- if section.blocks.size > 0 -%}
  <style>
    #shopify-section-{{ section.id }} {
      position: relative;
      z-index: 10;
    }
    .custom-announcement-bar {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      font-size: {{ font_size }}px;
      line-height: 1.4;
      width: 100%;
      background-color: {{ announcement_bg }};
      color: {{ announcement_text_color }};
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .custom-announcement-bar__container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 15px;
    }
    .custom-announcement-bar__wrapper {
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      min-height: 24px;
      gap: 20px;
      width: 100%;
    }
    .custom-announcement-bar__arrow {
      background: none !important;
      border: none !important;
      padding: 6px !important;
      cursor: pointer !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      color: inherit !important;
      opacity: 0.75 !important;
      transition: opacity 0.2s ease, transform 0.2s ease !important;
      flex: 0 0 auto !important;
    }
    .custom-announcement-bar__arrow:hover {
      opacity: 1 !important;
      transform: scale(1.15) !important;
    }
    .custom-announcement-bar__arrow svg {
      width: 10px !important;
      height: 16px !important;
      display: block !important;
      fill: none !important;
    }
    .custom-announcement-bar__arrow svg path {
      stroke: currentColor !important;
      stroke-width: 2px !important;
      fill: none !important;
      stroke-linecap: round !important;
      stroke-linejoin: round !important;
    }
    .custom-announcement-bar__slider {
      flex: 0 1 auto;
      max-width: 800px;
      min-width: 0;
      display: flex;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }
    .custom-announcement-bar__item {
      display: none;
      opacity: 0;
      width: 100%;
      text-align: center;
      transition: opacity 0.4s ease-in-out;
    }
    .custom-announcement-bar__item.is-active {
      display: block;
    }
    .custom-announcement-bar__item.is-visible {
      opacity: 1;
    }
    .custom-announcement-bar__link {
      color: inherit;
      text-decoration: none;
      display: inline-block;
      transition: opacity 0.2s ease;
    }
    .custom-announcement-bar__link:hover {
      opacity: 0.85;
    }
    .custom-announcement-bar__text strong, 
    .custom-announcement-bar__text b {
      font-weight: 700;
    }

    /* Desktop and Mobile Text classes */
    .custom-announcement-bar__text--desktop {
      display: inline;
    }
    .custom-announcement-bar__text--mobile {
      display: none;
    }

    @media (max-width: 767px) {
      .custom-announcement-bar__wrapper {
        gap: 0;
      }
      .custom-announcement-bar__arrow {
        display: none !important; /* Hide arrows completely on mobile */
      }
      .custom-announcement-bar__slider {
        max-width: 100%;
      }
      .custom-announcement-bar {
        font-size: calc({{ font_size }}px - 2px); /* Scale down font size on mobile */
      }
      .custom-announcement-bar__text--desktop {
        display: none;
      }
      .custom-announcement-bar__text--mobile {
        display: inline;
      }
      .custom-announcement-bar__item {
        white-space: nowrap; /* Single line, no wrap on mobile */
      }
    }
  </style>

  <div class="custom-announcement-bar" id="AnnouncementBar-{{ section.id }}">
    <div class="custom-announcement-bar__container">
      <div class="custom-announcement-bar__wrapper">
        
        {%- if section.blocks.size > 1 -%}
          <button type="button" class="custom-announcement-bar__arrow custom-announcement-bar__arrow--prev" aria-label="Previous announcement">
            <svg width="10" height="16" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 9L1 5L5 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}

        <div class="custom-announcement-bar__slider">
          {%- for block in section.blocks -%}
            <div class="custom-announcement-bar__item {% if forloop.first %}is-active is-visible{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="custom-announcement-bar__link">
              {%- endif -%}
              
              <span class="custom-announcement-bar__text custom-announcement-bar__text--desktop">{{ block.settings.text }}</span>
              
              {%- if block.settings.text_mobile != blank -%}
                <span class="custom-announcement-bar__text custom-announcement-bar__text--mobile">{{ block.settings.text_mobile }}</span>
              {%- else -%}
                <span class="custom-announcement-bar__text custom-announcement-bar__text--mobile">{{ block.settings.text }}</span>
              {%- endif -%}

              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        {%- if section.blocks.size > 1 -%}
          <button type="button" class="custom-announcement-bar__arrow custom-announcement-bar__arrow--next" aria-label="Next announcement">
            <svg width="10" height="16" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 9L5 5L1 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}

      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const sectionContainer = document.querySelector('#AnnouncementBar-{{ section.id }}');
      if (!sectionContainer) return;

      const slides = sectionContainer.querySelectorAll('.custom-announcement-bar__item');
      if (slides.length <= 1) return;

      let currentIndex = 0;
      let autoplayTimer = null;
      const autoplaySpeed = {{ change_slides_speed }};
      const isAutoplay = {{ auto_rotate }};

      function showSlide(index) {
        if (index === currentIndex) return;

        const activeSlide = sectionContainer.querySelector('.custom-announcement-bar__item.is-active');
        const nextSlide = slides[index];

        activeSlide.classList.remove('is-visible');

        setTimeout(() => {
          activeSlide.classList.remove('is-active');
          nextSlide.classList.add('is-active');
          
          // trigger reflow
          nextSlide.offsetHeight;
          
          nextSlide.classList.add('is-visible');
        }, 300);

        currentIndex = index;
      }

      function nextSlide() {
        let nextIndex = currentIndex + 1;
        if (nextIndex >= slides.length) {
          nextIndex = 0;
        }
        showSlide(nextIndex);
      }

      // Start autoplay initially
      if (isAutoplay && autoplaySpeed > 0) {
        autoplayTimer = setInterval(nextSlide, autoplaySpeed);
      }

      function prevSlide() {
        let prevIndex = currentIndex - 1;
        if (prevIndex < 0) {
          prevIndex = slides.length - 1;
        }
        showSlide(prevIndex);
      }

      function resetAutoplay() {
        if (autoplayTimer) {
          clearInterval(autoplayTimer);
          autoplayTimer = setInterval(nextSlide, autoplaySpeed);
        }
      }

      const prevBtn = sectionContainer.querySelector('.custom-announcement-bar__arrow--prev');
      const nextBtn = sectionContainer.querySelector('.custom-announcement-bar__arrow--next');

      if (prevBtn && nextBtn) {
        prevBtn.addEventListener('click', function() {
          prevSlide();
          resetAutoplay();
        });

        nextBtn.addEventListener('click', function() {
          nextSlide();
          resetAutoplay();
        });
      }
    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Custom Announcement Bar",
  "class": "section-custom-announcement-bar",
  "limit": 1,
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color",
      "id": "announcement_bg",
      "label": "Background Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "announcement_text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 13
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate announcements",
      "default": true
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 5,
      "max": 25,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 5,
      "max": 25,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Summer sale discount off 50%. <strong>Shop Sale</strong>",
          "label": "Text"
        },
        {
          "type": "inline_richtext",
          "id": "text_mobile",
          "label": "Text (Mobile) - Optional"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Announcement Bar",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
