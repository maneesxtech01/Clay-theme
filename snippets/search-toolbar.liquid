{%- liquid
  assign enable_filtering = enable_filtering
  assign default_filter = default_filter
  assign filter_layout = filter_layout
  assign number_products_per_page = section_st.number_products_per_page
  assign sorting = section_st.sorting
  assign products_column = products_column
-%}
{% liquid
  assign enable_rtl = settings.rtl
  assign iso_code = request.locale.iso_code
  assign lis_language_rtl = settings.language_rtl
  if lis_language_rtl != blank
    if lis_language_rtl contains iso_code
      assign enable_rtl = true
    else
      assign enable_rtl = false
    endif
  endif
%}

<!-- Desktop Search Toolbar -->
<div class="toolbar toolbar-products toolbar-desktop hidden-md gap-30 align-center mb-20{% if filter_layout == 'horizontal' %} mt-1025-60{% endif %}" style="display: none;">
  <!-- Left Side: Results Count -->
  <div class="toolbar-left flex align-center">
    {%- if number_products_per_page and search.results.size > 0 -%}
      <div class="toolbar-amount relative" id="toolbar-amount">
        {%- if search.results_count -%}
          {{ 'templates.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
        {%- elsif search.products_count == search.all_products_count -%}
          {{ 'products.facets.product_count_simple' | t: count: search.products_count }}
        {%- else -%}
          {{ 'products.facets.product_count' | t: product_count: search.products_count, count: search.all_products_count }}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Right Side: Sort By Dropdown -->
  {%- if sorting and enable_filtering -%}
    <div class="toolbar-sorter sorter flex gap-10 align-center relative flex-1 flex-end">
      <div class="select-custom pointer user-select-none">
        {%- assign sort_by = search.sort_by | default: search.default_sort_by -%}
        {%- liquid
          assign current_sort_name = 'Best Selling'
          case sort_by
            when 'best-selling'
              assign current_sort_name = 'Best Selling'
            when 'created-descending'
              assign current_sort_name = 'Newest'
            when 'title-ascending'
              assign current_sort_name = 'A-Z'
            when 'title-descending'
              assign current_sort_name = 'Z-A'
            when 'price-ascending'
              assign current_sort_name = 'Price (low to high)'
            when 'price-descending'
              assign current_sort_name = 'Price (high to low)'
            else
              for option in search.sort_options
                if option.value == sort_by
                  assign current_sort_name = option.name
                endif
              endfor
          endcase
        -%}
        <select-sorter class="select-selected user-select-none inline-flex align-center gap-10 gap-lg-20 lh-normal pointer overlay">
          <div class="flex flex-column align-start">
            <span class="sort-by-label">{{- 'products.facets.sort_by_label' | t -}}</span>
            <span class="sort-by-active heading-color subheading_weight">
              {{ current_sort_name }}
            </span>
          </div>
          <svg class="icon-down transition active-rotated" width="10" height="6">
            <use href="#icon-arrow-down"></use>
          </svg>
        </select-sorter>
        <div
          class="select-custom__content facet-filters__sort invisible transition rounded-5 select__select absolute shadow list-none z-2 py-20 px-25 color-default{% if enable_rtl %} left-0{% else %} right-0{% endif %}"
          id="SortBy"
          aria-describedby="a11y-refresh-page-message"
        >
          <icon-close class="pointer-none border bg-white inline-flex hidden-sm mx-auto rounded-50 overflow-hidden absolute top-0 inset-x-0 w-50 h-50 content-center heading-color">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" class="transition">
              <use href="#icon-close"></use>
            </svg>
          </icon-close>
          <div class="h-full overflow-auto sort-by-radio-list">
            {%- assign sort_options = "best-selling|Best Selling,created-descending|Newest,title-ascending|A-Z,title-descending|Z-A,price-ascending|Price (low to high),price-descending|Price (high to low)" | split: ',' -%}
            {%- for option in sort_options -%}
              {%- assign option_parts = option | split: '|' -%}
              {%- assign val = option_parts[0] -%}
              {%- assign label = option_parts[1] -%}
              
              <filter-sort
                class="filter-sort-option flex align-center gap-10 py-8 pointer text-color hover-heading-color transition body_weight"
                value="{{ val }}"
                {% if val == sort_by %}
                  selected="selected"
                {% endif %}
              >
                <span class="custom-radio-button inline-flex content-center rounded-50 border relative {% if val == sort_by %}checked{% endif %}" style="width: 18px; height: 18px; flex-shrink: 0;">
                  <span class="custom-radio-dot absolute rounded-50" style="width: 8px; height: 8px; top: 4px; left: 4px; display: {% if val == sort_by %}block{% else %}none{% endif %};"></span>
                </span>
                <span>{{ label }}</span>
              </filter-sort>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
</div>

<!-- Mobile Search Toolbar -->
<div class="toolbar toolbar-products toolbar-mobile hidden block-md align-center justify-content-between mb-20" style="display: flex;">
  <!-- Left Side: Filter button -->
  {%- if enable_filtering -%}
    <btn-filter
      class="btn-filter border flex gap-10 align-center px-15 py-10 pointer rounded-5 heading-style transition mr-15"
      data-filter-layout="{{ filter_layout }}"
    >
      <svg width="14" height="15" viewBox="0 0 14 15" fill="none">
        <path d="M12.8333 2.16666H1.16663L5.83329 7.67499V11.5L8.16663 12.6667V7.67499L12.8333 2.16666Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {{ 'collections.toolbar.filter' | t }}
    </btn-filter>
  {%- endif -%}
</div>
